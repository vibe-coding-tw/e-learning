{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/paymentNotify",
        "function": "paymentNotify"
      },
      {
        "source": "/maintenance/update-url",
        "run": {
            "serviceId": "maintenanceUpdateClassroomUrl",
            "region": "asia-east1"
        }
      },
      {
        "source": "/courses/**",
        "function": "serveCourse"
      }
    ]
  }
}
