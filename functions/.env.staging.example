# Staging environment for functions/
# Copy to functions/.env when testing locally against staging settings.

ECPAY_MERCHANT_ID=YOUR_STAGING_MERCHANT_ID
ECPAY_HASH_KEY=YOUR_STAGING_HASH_KEY
ECPAY_HASH_IV=YOUR_STAGING_HASH_IV
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_LOGISTICS_MAP_URL=https://logistics-stage.ecpay.com.tw/Express/map
ECPAY_LOGISTICS_QUERY_URL=https://logistics-stage.ecpay.com.tw/Express/Query
MAIL_USER=staging-mail@example.com
MAIL_PASS=YOUR_STAGING_MAIL_PASSWORD
ADMIN_EMAIL=staging-admin@example.com
GITHUB_WEBHOOK_SECRET=YOUR_STAGING_GITHUB_WEBHOOK_SECRET
GITHUB_CLASSROOM_ORG=vibe-coding-classroom-staging
GITHUB_ORG_ADMIN_TOKEN=YOUR_STAGING_GITHUB_ORG_ADMIN_TOKEN
APP_BASE_URL=https://staging.example.com
ECPAY_CHECK_MAC_ALGO=sha256
