#!/usr/bin/env bash
# pre-commit hook: 檢查關鍵檔案是否被意外刪除
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
DELETED=$(git diff --cached --name-status --diff-filter=D 2>/dev/null | awk '{print $2}')

CRITICAL_FILES=(
  "public/js/firebase-local.js"
  "public/js/nav-component.js"
  "public/js/course-shared.js"
  "shared-function-core/index.js"
  "shared-function-core/access-utils-core.js"
  "shared-function-core/package.json"
)

for file in "${CRITICAL_FILES[@]}"; do
  if echo "${DELETED}" | grep -Fx "${file}" >/dev/null; then
    echo ""
    echo "❌  pre-commit 拒絕提交：偵測到關鍵檔案被刪除"
    echo "    檔案: ${file}"
    echo "    如確定要刪除，請加入 --no-verify 跳過檢查"
    echo ""
    exit 1
  fi
done
